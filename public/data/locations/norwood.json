ing include...\nNorwood and Placerville, including areas along Highway 145.","ends":"2026-07-21T18:30:00-06:00","severity":"Severe","areaDesc":"Montrose, CO; San Miguel, CO","id":"urn:oid:2.49.0.1.840.0.c0abdd160d0ccc9d0de9aa7b56586c5da7f70641.001.1","url":"https://api.weather.gov/alerts/urn:oid:2.49.0.1.840.0.c0abdd160d0ccc9d0de9aa7b56586c5da7f70641.001.1"}],"afd":{"office":"GJT","issued":"2026-07-21T17:53:00+00:00","snippet":"000 FXUS65 KGJT 211753 AFDGJT Area Forecast Discussion National Weather Service Grand Junction CO 1153 AM MDT Tue Jul 21 2026 .KEY MESSAGES... - Showers and storms will continue this week each afternoon and evening, with coverage becoming more widespread by Tuesday and Wednesday. - Primary threats include heavy rainfall, lightning, and outflow winds up to 30-40 mph. Small hail cannot be ruled out ","url":"https://forecast.weather.gov/product.php?site=GJT&issuedby=GJT&product=AFD&format=CI"},"hwo":null,"coagmet":{"station_id":"nwd01","station_name":"Norwood","distance_km":2.3,"soil_temp_5cm_f":80.24,"soil_temp_15cm_f":69.66,"soil_moisture_5cm":null,"soil_moisture_15cm":null,"precip_in":null,"eto_in":null,"vapor_pressure":null,"solar_radiation":22.38,"wind_speed_mph":18.32,"air_temp_f":68.2,"relative_humidity":0.633,"url":"https://coagmet.colostate.edu/station/nwd01"},"aviation":{"icao":"KTEX","distance_km":0,"raw_metar":"METAR KTEX 212135Z AUTO 11012G21KT 10SM CLR 27/03 A3042 RMK AO2","temp_f":81,"wind_dir":110,"wind_kt":12,"gust_kt":21,"visibility":"10+","cover":"CLR","flight_category":"VFR","altimeter":1030.2,"observed":1784669700,"raw_taf":null,"url":"https://aviationweather.gov/data/metar/?ids=KTEX&hours=0"},"purpleair":{"name":"APCD Norwood","distance_km":0.1,"pm25":5.8,"humidity":62,"temperature_f":70,"aqi_pm25":24,"url":"https://map.purpleair.com/"},"airnow":{"aqi":44,"category":"Good","parameter":"PM10","reporting_area":"Telluride","observed":"2026-07-21 14","by_parameter":{"PM2.5":{"aqi":38,"category":"Good","reporting_area":"Tellurid