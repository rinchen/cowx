{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cowx.dev/schemas/meta.schema.json",
  "title": "CowxMeta",
  "type": "object",
  "required": ["generatedAt", "version", "sources"],
  "additionalProperties": false,
  "properties": {
    "generatedAt": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp when data was last fetched"
    },
    "version": {
      "type": "string",
      "description": "Schema or build version for consumers"
    },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "status"],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "description": "Source identifier (e.g. purpleair, airnow, openmeteo)"
          },
          "status": {
            "type": "string",
            "enum": ["ok", "partial", "error", "skipped"]
          },
          "fetchedAt": {
            "type": "string",
            "format": "date-time"
          },
          "error": {
            "type": "string"
          }
        }
      }
    },
    "locationCount": {
      "type": "integer",
      "minimum": 0
    }
  }
}
