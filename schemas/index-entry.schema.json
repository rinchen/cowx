{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cowx.dev/schemas/index-entry.schema.json",
  "title": "COWXIndexEntry",
  "description": "Slim location index entry for client-side lookup",
  "type": "object",
  "required": ["slug", "name", "lat", "lon"],
  "additionalProperties": false,
  "properties": {
    "slug": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$",
      "description": "URL-safe location identifier"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "lat": {
      "type": "number",
      "minimum": -90,
      "maximum": 90
    },
    "lon": {
      "type": "number",
      "minimum": -180,
      "maximum": 180
    },
    "region": {
      "type": "string"
    },
    "county": {
      "type": "string"
    },
    "elevation_ft": {
      "type": "number"
    },
    "temp_f": {
      "type": ["number", "null"]
    },
    "condition": {
      "type": ["string", "null"]
    },
    "humidity": {
      "type": ["number", "null"]
    },
    "wind_speed_mph": {
      "type": ["number", "null"]
    },
    "aqi": {
      "type": ["number", "null"]
    },
    "nws_alert": {
      "type": "boolean"
    },
    "forecast_stale": {
      "type": "boolean"
    },
    "updated_at": {
      "type": "string"
    }
  }
}
